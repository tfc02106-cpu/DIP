<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Banana Ripeness Detection</title>
<style>
  body { font-family: sans-serif; text-align: center; margin: 0; padding: 0; background: #f0f0f0; }
  video { width: 100%; max-width: 600px; }
  #info { margin-top: 20px; font-size: 18px; font-weight: bold; }
</style>
</head>
<body>

<h2>Banana Ripeness Detection</h2>
<video id="video" autoplay playsinline></video>
<canvas id="canvas" style="display:none;"></canvas>
<div id="info">Detecting...</div>

<script>
const thresholds = { unripe: {a:-8}, ripe: {b:45}, veryRipe: {a:10} }; // 請修改這邊0的數值 熟跟不熟就好

function rgbToXyz(r, g, b) {
    r /= 255; g /= 255; b /= 255;
    r = r>0.04045?Math.pow((r+0.055)/1.055,2.4):r/12.92;
    g = g>0.04045?Math.pow((g+0.055)/1.055,2.4):g/12.92;
    b = b>0.04045?Math.pow((b+0.055)/1.055,2.4):b/12.92;
    const X = r*0.4124 + g*0.3576 + b*0.1805;
    const Y = r*0.2126 + g*0.7152 + b*0.0722;
    const Z = r*0.0193 + g*0.1192 + b*0.9505;
    return {X, Y, Z};
}

function xyzToLab({X,Y,Z}) {
    const refX=0.95047, refY=1.000, refZ=1.08883;
    X/=refX; Y/=refY; Z/=refZ;
    X=X>0.008856?Math.cbrt(X):7.787*X+16/116;
    Y=Y>0.008856?Math.cbrt(Y):7.787*Y+16/116;
    Z=Z>0.008856?Math.cbrt(Z):7.787*Z+16/116;
    const L = 116*Y-16;
    const a = 500*(X-Y);
    const b = 200*(Y-Z);
    return {L, a, b};  
}

function classifyLab({a,b}) {
    if(a<thresholds.unripe.a) return "不熟";
    if(b>thresholds.ripe.b) return "熟"; //-5 45 10
    if(a>thresholds.veryRipe.a) return "熟透";
    return "未知";
}

const video=document.getElementById('video');
navigator.mediaDevices.getUserMedia({video:{facingMode:'environment'}})
.then(stream=>video.srcObject=stream);

const canvas=document.getElementById('canvas');
const ctx=canvas.getContext('2d');
const infoDiv=document.getElementById('info');

setInterval(()=>{
    canvas.width=video.videoWidth;
    canvas.height=video.videoHeight;
    ctx.drawImage(video,0,0,canvas.width,canvas.height);
    const centerX=Math.floor(canvas.width/2);
    const centerY=Math.floor(canvas.height/2);
    const pixel=ctx.getImageData(centerX,centerY,1,1).data;
    const lab=xyzToLab(rgbToXyz(pixel[0],pixel[1],pixel[2]));
    const result=classifyLab(lab);
    infoDiv.innerHTML=
        `RGB: (${pixel[0]}, ${pixel[1]}, ${pixel[2]})<br>`+
        `Lab: (L*: ${lab.L.toFixed(1)}, a*: ${lab.a.toFixed(1)}, b*: ${lab.b.toFixed(1)})<br>`+
        `熟度: ${result}`;
}, 200);
</script>

</body>
</html>
